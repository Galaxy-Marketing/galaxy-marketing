---
// Navbar principale — fond blanc, responsive avec menu hamburger mobile
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 bg-white shadow-sm transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 flex-shrink-0">
        <img
          src="/logo.png"
          alt="Galaxy Marketing"
          class="h-10 w-auto"
          onerror="this.style.display='none'; document.getElementById('logo-text').style.display='block';"
        />
        <span
          id="logo-text"
          class="text-gm-marine font-bold text-xl hidden"
          style="display:none;"
        >
          Galaxy Marketing
        </span>
      </a>

      <!-- Liens desktop -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/" class="text-gray-700 hover:text-gm-blue font-medium btn-transition">
          Accueil
        </a>
        <a href="/services" class="text-gray-700 hover:text-gm-blue font-medium btn-transition">
          Services
        </a>
        <a href="/#offres" class="text-gray-700 hover:text-gm-blue font-medium btn-transition">
          Offres
        </a>
        <a href="/contact" class="text-gray-700 hover:text-gm-blue font-medium btn-transition">
          Contact
        </a>
        <a
          href="/contact"
          class="bg-gm-blue text-white px-5 py-2 rounded-lg font-semibold btn-transition hover:bg-gm-indigo"
        >
          Demander un devis
        </a>
      </nav>

      <!-- Hamburger mobile -->
      <button
        id="hamburger"
        class="md:hidden flex flex-col gap-1.5 p-2"
        aria-label="Menu"
      >
        <span class="block w-6 h-0.5 bg-gm-marine"></span>
        <span class="block w-6 h-0.5 bg-gm-marine"></span>
        <span class="block w-6 h-0.5 bg-gm-marine"></span>
      </button>
    </div>
  </div>

  <!-- Menu mobile déroulant -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100">
    <div class="px-4 py-4 flex flex-col gap-4">
      <a href="/" class="text-gray-700 font-medium hover:text-gm-blue btn-transition">Accueil</a>
      <a href="/services" class="text-gray-700 font-medium hover:text-gm-blue btn-transition">Services</a>
      <a href="/#offres" class="text-gray-700 font-medium hover:text-gm-blue btn-transition">Offres</a>
      <a href="/contact" class="text-gray-700 font-medium hover:text-gm-blue btn-transition">Contact</a>
      <a
        href="/contact"
        class="bg-gm-blue text-white px-5 py-2.5 rounded-lg font-semibold text-center btn-transition hover:bg-gm-indigo"
      >
        Demander un devis
      </a>
    </div>
  </div>
</header>
