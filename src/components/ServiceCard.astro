---
// Carte de service — icône SVG + titre + description
interface Props {
  title: string;
  description: string;
  icon: 'computer' | 'location' | 'star';
}

const { title, description, icon } = Astro.props;
---

<div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 card-hover fade-in-up">
  <!-- Icône -->
  <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center mb-5">
    {icon === 'computer' && (
      <svg class="w-7 h-7 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
    )}
    {icon === 'location' && (
      <svg class="w-7 h-7 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
    )}
    {icon === 'star' && (
      <svg class="w-7 h-7 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
      </svg>
    )}
  </div>

  <h3 class="text-xl font-bold text-gm-marine mb-3">{title}</h3>
  <p class="text-gray-600 leading-relaxed">{description}</p>
</div>
