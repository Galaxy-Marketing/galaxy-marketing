<!-- Script particules étoiles pour le hero -->
<script>
  const canvas = document.getElementById('stars-canvas') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    type Star = { x:number; y:number; r:number; R:number; G:number; B:number; op:number; maxOp:number; minOp:number; tw:number; dir:number; dx:number; dy:number; };
    let stars: Star[] = [];

    const resize = () => {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    };

    const init = () => {
      stars = [];
      const total = Math.max(500, Math.floor(canvas.width * canvas.height / 1100));
      for (let i = 0; i < total; i++) {
        const rand = Math.random();
        let R: number, G: number, B: number;
        if (rand < 0.38) { R=255; G=255; B=255; }           // 38% blanc pur
        else if (rand < 0.68) { R=210; G=228; B=255; }      // 30% bleu très clair
        else if (rand < 0.86) { R=66;  G=165; B=245; }      // 18% bleu vif
        else { R=180; G=140; B=255; }                        // 14% mauve — profondeur

        const sz = Math.random();
        const r = sz < 0.62
          ? Math.random() * 0.55 + 0.12   // petites (lointaines)
          : sz < 0.91
          ? Math.random() * 0.85 + 0.55   // moyennes
          : Math.random() * 1.4 + 1.15;   // grandes brillantes (rares)

        const minOp = Math.random() * 0.06 + 0.03;
        const maxOp = Math.random() * 0.55 + 0.30;

        stars.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          r, R, G, B,
          op: Math.random() * (maxOp - minOp) + minOp,
          maxOp, minOp,
          tw: Math.random() * 0.006 + 0.0015,
          dir: Math.random() > 0.5 ? 1 : -1,
          dx: (Math.random() - 0.5) * 0.045,
          dy: -(Math.random() * 0.09 + 0.008),
        });
      }
    };

    const draw = () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      stars.forEach(s => {
        s.op += s.tw * s.dir;
        if (s.op >= s.maxOp || s.op <= s.minOp) s.dir *= -1;
        s.op = Math.max(s.minOp, Math.min(s.maxOp, s.op));
        s.x += s.dx;
        s.y += s.dy;
        if (s.y < -4) { s.y = canvas.height + 4; s.x = Math.random() * canvas.width; }
        if (s.x < -4) s.x = canvas.width + 4;
        if (s.x > canvas.width + 4) s.x = -4;

        if (s.r > 1.1) {
          const g = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, s.r * 4.5);
          g.addColorStop(0, `rgba(${s.R},${s.G},${s.B},${s.op * 0.35})`);
          g.addColorStop(1, `rgba(${s.R},${s.G},${s.B},0)`);
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.r * 4.5, 0, Math.PI * 2);
          ctx.fillStyle = g;
          ctx.fill();
        }

        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${s.R},${s.G},${s.B},${s.op})`;
        ctx.fill();
      });
      requestAnimationFrame(draw);
    };

    window.addEventListener('resize', () => { resize(); init(); });
    resize();
    init();
    draw();
  }
</script>

