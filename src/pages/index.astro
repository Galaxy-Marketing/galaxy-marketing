---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import OffreCard from '../components/OffreCard.astro';
---

<Layout
  title="Galaxy Marketing — Votre présence digitale, pensée pour vous"
  description="Galaxy Marketing : agence spécialisée en site web vitrine, fiche Google Business et identité visuelle pour les entrepreneurs et entreprises locales."
>

  <!-- ============================
       SECTION 1 — HERO
       ============================ -->
  <section class="relative min-h-screen flex items-center justify-center bg-white overflow-hidden">
    <!-- Étoiles flottantes CSS -->
    <div class="stars-container" aria-hidden="true">
      <div class="star" style="top:10%; left:8%;  --duration:7s;  --delay:0s;"></div>
      <div class="star" style="top:20%; left:85%; --duration:9s;  --delay:1s;"></div>
      <div class="star" style="top:35%; left:15%; --duration:6s;  --delay:0.5s;"></div>
      <div class="star" style="top:55%; left:90%; --duration:8s;  --delay:2s;"></div>
      <div class="star" style="top:70%; left:5%;  --duration:10s; --delay:0.3s;"></div>
      <div class="star" style="top:80%; left:75%; --duration:7s;  --delay:1.5s;"></div>
      <div class="star" style="top:15%; left:50%; --duration:9s;  --delay:0.8s;"></div>
      <div class="star" style="top:65%; left:40%; --duration:6s;  --delay:2.5s;"></div>
      <div class="star" style="top:40%; left:70%; --duration:11s; --delay:0.2s;"></div>
      <div class="star" style="top:88%; left:30%; --duration:8s;  --delay:1.8s;"></div>
      <div class="star" style="top:5%;  left:35%; --duration:7s;  --delay:3s;"></div>
      <div class="star" style="top:50%; left:55%; --duration:9s;  --delay:0.7s;"></div>
      <div class="star" style="top:25%; left:28%; --duration:6s;  --delay:1.2s;"></div>
      <div class="star" style="top:75%; left:60%; --duration:10s; --delay:2.2s;"></div>
      <div class="star" style="top:92%; left:80%; --duration:8s;  --delay:0.4s;"></div>
      <div class="star" style="top:45%; left:22%; --duration:7s;  --delay:3.5s;"></div>
      <div class="star" style="top:30%; left:95%; --duration:9s;  --delay:1.6s;"></div>
      <div class="star" style="top:60%; left:12%; --duration:6s;  --delay:2.8s;"></div>
      <div class="star" style="top:82%; left:48%; --duration:11s; --delay:0.9s;"></div>
      <div class="star" style="top:18%; left:63%; --duration:8s;  --delay:1.4s;"></div>
    </div>

    <!-- Contenu hero -->
    <div class="relative z-10 text-center max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-blue-50 border border-blue-100 rounded-full px-4 py-1.5 mb-8">
        <span class="w-2 h-2 bg-gm-light rounded-full animate-pulse"></span>
        <span class="text-gm-blue text-sm font-medium">Agence marketing digitale</span>
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold text-gm-marine leading-tight mb-6">
        Votre présence digitale,<br />
        <span class="text-gm-blue">pensée pour vous.</span>
      </h1>

      <p class="text-xl sm:text-2xl text-gray-500 mb-10 font-light">
        Site web · Fiche Google · Identité visuelle
      </p>

      <!-- Boutons CTA -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#offres"
          class="bg-gm-blue text-white px-8 py-4 rounded-xl font-semibold text-lg btn-transition hover:bg-gm-indigo shadow-lg shadow-blue-200"
        >
          Voir nos offres
        </a>
        <a
          href="/contact"
          class="border-2 border-gm-marine text-gm-marine px-8 py-4 rounded-xl font-semibold text-lg btn-transition hover:bg-gm-marine hover:text-white"
        >
          Nous contacter
        </a>
      </div>

      <!-- Indicateur scroll -->
      <div class="mt-16 flex flex-col items-center gap-2 animate-bounce">
        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
    </div>
  </section>

  <!-- ============================
       SECTION 2 — SERVICES
       ============================ -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-in-up">
        <h2 class="text-4xl font-extrabold text-gm-marine mb-4">Nos services</h2>
        <p class="text-gray-500 text-lg max-w-xl mx-auto">
          Tout ce qu'il faut pour une présence en ligne professionnelle et efficace.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <ServiceCard
          icon="computer"
          title="Site web vitrine"
          description="Sites vitrines modernes, responsives et optimisés pour attirer vos clients."
        />
        <ServiceCard
          icon="location"
          title="Fiche Google"
          description="Optimisation complète de votre fiche Google Business pour être trouvé localement."
        />
        <ServiceCard
          icon="star"
          title="Identité visuelle"
          description="Logo, carte de visite et flyer pour une image de marque professionnelle."
        />
      </div>
    </div>
  </section>

  <!-- ============================
       SECTION 3 — OFFRES
       ============================ -->
  <section id="offres" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-20 fade-in-up">
        <h2 class="text-4xl font-extrabold text-gm-marine mb-4">Nos offres</h2>
        <p class="text-gray-500 text-lg max-w-xl mx-auto">
          Des formules claires et adaptées à chaque besoin et budget.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center">
        <OffreCard
          name="Essentiel"
          price="À partir de 250€"
          features={[
            'Fiche Google optimisée + visuels',
            '3 posts Google planifiés',
            'Carte NFC + QR code',
            'Guide PDF offert',
          ]}
        />
        <OffreCard
          name="Pro"
          price="À partir de 900€"
          popular={true}
          features={[
            'Tout l\'Essentiel inclus',
            'Site web one-page professionnel',
            'Design responsive mobile et desktop',
            'Formulaire de contact intégré',
            'Animations incluses',
          ]}
        />
        <OffreCard
          name="Galaxy"
          price="À partir de 1 200€"
          features={[
            'Tout le Pro inclus',
            'Logo + identité visuelle complète',
            'Carte de visite et flyer',
            'Livraison en haute résolution',
          ]}
        />
      </div>
    </div>
  </section>

  <!-- ============================
       SECTION 4 — SERVICES À LA CARTE
       ============================ -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-in-up">
        <h2 class="text-4xl font-extrabold text-gm-marine mb-4">Besoin d'autre chose ?</h2>
        <p class="text-gray-500 text-lg">Des services supplémentaires selon vos besoins.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Carte 1 -->
        <div class="bg-white rounded-2xl p-7 border border-gray-100 shadow-sm card-hover fade-in-up flex flex-col gap-4">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gm-marine">Pack 12 visuels réseaux sociaux</h3>
          <p class="text-gray-500 text-sm flex-1">12 visuels personnalisés aux couleurs de votre marque pour vos réseaux sociaux.</p>
          <a href="/contact" class="bg-gm-blue text-white text-center py-2.5 px-5 rounded-lg font-semibold text-sm btn-transition hover:bg-gm-indigo">
            Sur devis
          </a>
        </div>

        <!-- Carte 2 -->
        <div class="bg-white rounded-2xl p-7 border border-gray-100 shadow-sm card-hover fade-in-up flex flex-col gap-4">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gm-marine">Chatbot sur site</h3>
          <p class="text-gray-500 text-sm flex-1">Assistant virtuel intelligent intégré à votre site pour répondre à vos visiteurs 24h/24.</p>
          <a href="/contact" class="bg-gm-blue text-white text-center py-2.5 px-5 rounded-lg font-semibold text-sm btn-transition hover:bg-gm-indigo">
            Sur devis
          </a>
        </div>

        <!-- Carte 3 -->
        <div class="bg-white rounded-2xl p-7 border border-gray-100 shadow-sm card-hover fade-in-up flex flex-col gap-4">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gm-marine">Système de réservation en ligne</h3>
          <p class="text-gray-500 text-sm flex-1">Permettez à vos clients de réserver directement depuis votre site, à toute heure.</p>
          <a href="/contact" class="bg-gm-blue text-white text-center py-2.5 px-5 rounded-lg font-semibold text-sm btn-transition hover:bg-gm-indigo">
            Sur devis
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================
       SECTION 5 — POURQUOI GALAXY MARKETING
       ============================ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-in-up">
        <h2 class="text-4xl font-extrabold text-gm-marine mb-4">Pourquoi Galaxy Marketing ?</h2>
        <p class="text-gray-500 text-lg max-w-xl mx-auto">
          Ce qui nous différencie et fait la confiance de nos clients.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        <!-- Argument 1 -->
        <div class="flex gap-5 fade-in-up">
          <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gm-marine mb-2">Livraison rapide</h3>
            <p class="text-gray-500 leading-relaxed">Votre projet livré dans les meilleurs délais, sans compromettre la qualité.</p>
          </div>
        </div>

        <!-- Argument 2 -->
        <div class="flex gap-5 fade-in-up">
          <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gm-marine mb-2">Sur mesure</h3>
            <p class="text-gray-500 leading-relaxed">Chaque projet est unique et entièrement adapté à vos besoins et votre secteur d'activité.</p>
          </div>
        </div>

        <!-- Argument 3 -->
        <div class="flex gap-5 fade-in-up">
          <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gm-marine mb-2">Suivi complet</h3>
            <p class="text-gray-500 leading-relaxed">Accompagnement du début à la fin du projet, avec communication transparente à chaque étape.</p>
          </div>
        </div>

        <!-- Argument 4 -->
        <div class="flex gap-5 fade-in-up">
          <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gm-marine mb-2">Résultat professionnel</h3>
            <p class="text-gray-500 leading-relaxed">Une qualité professionnelle à chaque livraison, quel que soit la taille ou le budget du projet.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================
       SECTION 6 — CTA FINAL
       ============================ -->
  <section class="py-24 gradient-blue">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center fade-in-up">
      <h2 class="text-4xl sm:text-5xl font-extrabold text-white mb-6">
        Prêt à booster votre présence en ligne ?
      </h2>
      <p class="text-blue-200 text-xl mb-10">
        Discutons de votre projet. Devis gratuit, réponse sous 24h.
      </p>
      <a
        href="/contact"
        class="inline-block bg-white text-gm-blue px-10 py-4 rounded-xl font-bold text-lg btn-transition hover:bg-blue-50 shadow-xl"
      >
        Demander un devis gratuit
      </a>
    </div>
  </section>

</Layout>
