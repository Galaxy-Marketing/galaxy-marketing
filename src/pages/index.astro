---
import Layout from '../layouts/Layout.astro';
import OffreCard from '../components/OffreCard.astro';
---

<Layout
  title="Galaxy Marketing — Votre présence digitale, pensée pour vous"
  description="Galaxy Marketing : agence spécialisée en site web vitrine, fiche Google Business et identité visuelle pour les entrepreneurs et entreprises locales."
>

  <!-- ============================
       HERO — 3 cartes flottantes + animations entrée
       ============================ -->
  <section class="relative flex items-center overflow-hidden" style="background:linear-gradient(145deg, #04091E 0%, #080F30 20%, #0C1648 40%, #0A1238 60%, #06091E 100%); min-height:82vh;">

    <!-- Nébulosités CSS — bleu dominant, mauve profondeur -->
    <div class="nebula-blob" style="background:radial-gradient(circle, rgba(21,101,192,0.5) 0%, transparent 70%); width:750px; height:750px; left:-180px; top:-140px; animation:nebula-1 24s ease-in-out infinite;"></div>
    <div class="nebula-blob" style="background:radial-gradient(circle, rgba(66,165,245,0.22) 0%, transparent 70%); width:600px; height:600px; right:-120px; bottom:-60px; animation:nebula-2 30s ease-in-out infinite; animation-delay:-12s;"></div>
    <div class="nebula-blob" style="background:radial-gradient(circle, rgba(100,60,210,0.13) 0%, transparent 70%); width:500px; height:500px; left:38%; top:5%; animation:nebula-3 20s ease-in-out infinite; animation-delay:-7s;"></div>
    <div class="nebula-blob" style="background:radial-gradient(circle, rgba(30,80,180,0.28) 0%, transparent 70%); width:380px; height:380px; right:30%; bottom:10%; animation:nebula-4 26s ease-in-out infinite; animation-delay:-3s;"></div>
    <!-- Fondu bas vers la barre stats -->
    <div class="absolute bottom-0 left-0 right-0 pointer-events-none" style="height:100px; background:linear-gradient(to bottom, transparent, #0D1235);"></div>

    <!-- Canvas particules étoiles (par-dessus tout) -->
    <canvas id="stars-canvas" class="absolute inset-0 w-full h-full" style="z-index:1;" aria-hidden="true"></canvas>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- Texte gauche — animation ligne par ligne -->
        <div>
          <div class="hero-animate hero-animate-1 inline-flex items-center gap-2 rounded-full px-4 py-1.5 mb-8 border" style="background:rgba(66,165,245,0.1); border-color:rgba(66,165,245,0.3);">
            <span class="w-2 h-2 rounded-full animate-pulse" style="background:#42A5F5;"></span>
            <span class="text-sm font-medium" style="color:#42A5F5;">Agence marketing digitale</span>
          </div>

          <h1 class="font-extrabold leading-tight mb-6">
            <span class="hero-animate hero-animate-2 block text-5xl sm:text-6xl xl:text-7xl text-white">Votre présence</span>
            <span class="hero-animate hero-animate-3 block text-5xl sm:text-6xl xl:text-7xl text-white">digitale,</span>
            <span class="hero-animate hero-animate-4 block text-5xl sm:text-6xl xl:text-7xl" style="color:#42A5F5;">pensée pour vous.</span>
          </h1>

          <p class="hero-animate hero-animate-5 text-xl mb-10 font-light" style="color:rgba(255,255,255,0.55);">
            Site web · Fiche Google · Identité visuelle
          </p>

          <div class="hero-animate hero-animate-6 flex flex-col sm:flex-row gap-4">
            <a href="/services" class="text-white px-8 py-4 rounded-xl font-semibold text-lg btn-transition text-center shadow-lg" style="background:#1565C0;" onmouseover="this.style.background='#5C35B0'" onmouseout="this.style.background='#1565C0'">
              Voir nos services
            </a>
            <a href="/contact" class="px-8 py-4 rounded-xl font-semibold text-lg btn-transition text-center border-2 text-white" style="border-color:rgba(255,255,255,0.25);" onmouseover="this.style.borderColor='#42A5F5';this.style.color='#42A5F5'" onmouseout="this.style.borderColor='rgba(255,255,255,0.25)';this.style.color='white'">
              Nous contacter
            </a>
          </div>
        </div>

        <!-- 3 cartes flottantes droite -->
        <div class="hero-cards-container">

          <!-- Card 1 — Site web vitrine (haut gauche) -->
          <div class="float-a flex-shrink-0 lg:absolute lg:top-0 lg:left-0 w-72 rounded-2xl overflow-hidden shadow-2xl" style="background:rgba(15,20,50,0.9); border:1px solid rgba(255,255,255,0.12); backdrop-filter:blur(16px);">
            <!-- Mini browser chrome -->
            <div class="flex items-center gap-1.5 px-3 py-2.5" style="background:rgba(255,255,255,0.06); border-bottom:1px solid rgba(255,255,255,0.08);">
              <div class="w-2.5 h-2.5 rounded-full bg-red-400/80"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-400/80"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-400/80"></div>
              <div class="flex-1 rounded-full h-3.5 ml-1 flex items-center px-2" style="background:rgba(255,255,255,0.08);">
                <span class="text-white/30 text-xs">monentreprise.fr</span>
              </div>
            </div>
            <!-- Screenshot site -->
            <img
              src="/mockup-site.png"
              alt="Site web vitrine"
              class="w-full h-44 object-cover"
              style="object-position: 50% 0%;"
            />
            <!-- Info bas -->
            <div class="px-4 py-3">
              <p class="text-white font-bold text-sm">Site web vitrine</p>
              <p class="text-xs mt-0.5" style="color:rgba(255,255,255,0.4);">Livré clé en main</p>
            </div>
          </div>

          <!-- Card 2 — Fiche Google Maps (haut droite) -->
          <div class="float-b flex-shrink-0 lg:absolute lg:top-4 lg:right-0 w-60 rounded-2xl overflow-hidden shadow-2xl" style="background:white; border:1px solid rgba(0,0,0,0.1);">
            <!-- En-tête : logo Maps + nom -->
            <div class="flex items-center gap-2.5 px-3 py-3" style="border-bottom:1px solid #f1f3f4;">
              <div class="w-9 h-9 flex-shrink-0 flex items-center justify-center">
                <svg viewBox="0 0 24 24" class="w-8 h-8" xmlns="http://www.w3.org/2000/svg">
                  <defs>
                    <clipPath id="maps-pin2">
                      <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                    </clipPath>
                  </defs>
                  <g clip-path="url(#maps-pin2)">
                    <rect x="0" y="0" width="12" height="9" fill="#4285F4"/>
                    <rect x="12" y="0" width="12" height="9" fill="#EA4335"/>
                    <rect x="0" y="9" width="12" height="15" fill="#34A853"/>
                    <rect x="12" y="9" width="12" height="15" fill="#FBBC05"/>
                  </g>
                  <circle cx="12" cy="9" r="3" fill="white"/>
                </svg>
              </div>
              <div>
                <p class="font-bold text-sm leading-tight" style="color:#202124;">Mon entreprise</p>
                <p class="text-xs" style="color:#70757a;">Visible sur Google Maps</p>
              </div>
            </div>
            <!-- Photo boutique sans recadrage -->
            <img src="/boutique-google.png" alt="Mon entreprise" class="w-full" />
            <!-- Étoiles animées + avis + boutique -->
            <div class="px-3 py-2.5">
              <div class="flex items-center gap-1.5 mb-1.5">
                <span id="gcard-rating" class="font-bold text-sm" style="color:#F5A623;">2.0</span>
                <div class="relative" style="width:80px; height:14px;">
                  <div class="absolute inset-0 flex gap-0.5">
                    {[1,2,3,4,5].map(() => (
                      <svg class="w-3.5 h-3.5 text-gray-200" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                    ))}
                  </div>
                  <div id="gcard-star-fill" class="absolute inset-0 overflow-hidden flex gap-0.5" style="width:40%;">
                    {[1,2,3,4,5].map(() => (
                      <svg class="w-3.5 h-3.5 text-yellow-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                    ))}
                  </div>
                </div>
                <span id="gcard-reviews" class="text-xs" style="color:#70757a;">(20)</span>
              </div>
              <div class="flex items-center gap-1.5">
                <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" style="color:#1a73e8;">
                  <path d="M18 6h-2c0-2.21-1.79-4-4-4S8 3.79 8 6H6c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-8 4c0 .55-.45 1-1 1s-1-.45-1-1V8h2v2zm2-6c1.1 0 2 .9 2 2h-4c0-1.1.9-2 2-2zm4 6c0 .55-.45 1-1 1s-1-.45-1-1V8h2v2z"/>
                </svg>
                <span class="text-xs" style="color:#70757a;">Boutique</span>
              </div>
            </div>
          </div>

          <!-- Card 3 — Identité visuelle (bas centre) -->
          <div class="float-c flex-shrink-0 lg:absolute lg:bottom-0 lg:left-1/2 lg:-translate-x-1/2 w-64 rounded-2xl p-4 shadow-2xl" style="background:rgba(10,18,60,0.88); border:1px solid rgba(66,165,245,0.22); backdrop-filter:blur(16px);">
            <p class="text-white font-bold text-sm mb-3">Identité visuelle</p>
            <!-- Photo identité visuelle complète -->
            <img
              src="/carte-visite.png"
              alt="Identité visuelle"
              class="w-full rounded-xl shadow-xl"
            />
            <!-- Palette -->
            <div class="flex items-center justify-between mt-3">
              <div class="flex gap-1.5">
                <div class="w-4 h-4 rounded-full shadow" style="background:#C4785A;"></div>
                <div class="w-4 h-4 rounded-full shadow" style="background:#E8D5C4;"></div>
                <div class="w-4 h-4 rounded-full shadow" style="background:#7B8C6E;"></div>
                <div class="w-4 h-4 rounded-full shadow border border-white/20" style="background:#2C2018;"></div>
              </div>
              <p class="text-xs" style="color:rgba(255,255,255,0.45);">Logo · Carte · Flyer</p>
            </div>
          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- ============================
       STATS ANIMÉES — 3 chiffres clés
       ============================ -->
  <section class="py-12 relative overflow-hidden" style="background:linear-gradient(180deg, #0D1235 0%, #080F26 100%);">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">

        <!-- Stat 1 : 48h -->
        <div class="fade-in-up delay-100 text-center rounded-2xl px-8 py-7" style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.07);">
          <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:rgba(255,255,255,0.35);">Réponse garantie</p>
          <p class="text-5xl sm:text-6xl font-black text-white leading-none">
            <span class="counter" data-target="48" data-suffix="h">0h</span>
          </p>
        </div>

        <!-- Stat 2 : 100% — centrale mise en avant -->
        <div class="fade-in-up delay-200 text-center rounded-2xl px-8 py-7 relative overflow-hidden" style="background:linear-gradient(135deg, rgba(21,101,192,0.2) 0%, rgba(66,165,245,0.07) 100%); border:1px solid rgba(66,165,245,0.28);">
          <div class="absolute inset-0 pointer-events-none opacity-20" style="background:radial-gradient(ellipse at 50% 80%, rgba(66,165,245,0.45) 0%, transparent 70%);"></div>
          <p class="text-xs font-semibold uppercase tracking-widest mb-4 relative" style="color:rgba(66,165,245,0.65);">Satisfaction</p>
          <p class="text-5xl sm:text-6xl font-black leading-none relative" style="color:#42A5F5;">
            <span class="counter" data-target="100" data-suffix="%">0%</span>
          </p>
        </div>

        <!-- Stat 3 : Gratuit -->
        <div class="fade-in-up delay-300 text-center rounded-2xl px-8 py-7" style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.07);">
          <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:rgba(255,255,255,0.35);">Devis</p>
          <p class="text-5xl sm:text-6xl font-black leading-none" style="color:#42A5F5;">Gratuit</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================
       ROADMAP CLIENT — parcours
       ============================ -->
  <section class="py-20 relative overflow-hidden" style="background:#F8FAFF;">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-14 fade-in-up">
        <span class="text-sm font-semibold uppercase tracking-widest" style="color:#1565C0;">Votre parcours</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-gm-marine mt-2">De l'inconnu à l'incontournable</h2>
      </div>

      <div class="relative">
        <!-- Ligne horizontale desktop -->
        <div class="hidden lg:block absolute" style="top:31px; left:16%; right:16%; height:2px; background:linear-gradient(90deg, transparent, rgba(21,101,192,0.15) 15%, rgba(21,101,192,0.4) 50%, rgba(21,101,192,0.15) 85%, transparent);"></div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

          <!-- 1 : Être trouvé -->
          <div class="fade-in-up delay-100 flex lg:flex-col items-center gap-5 lg:gap-0 lg:text-center">
            <div class="relative z-10 w-16 h-16 rounded-full flex items-center justify-center flex-shrink-0" style="background:#E1EBF9; border:2px solid rgba(21,101,192,0.4);">
              <svg class="w-7 h-7" style="color:#1565C0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div class="lg:mt-4">
              <p class="font-bold text-sm text-gm-marine">Être trouvé</p>
              <p class="text-xs mt-1 text-gray-400">Fiche Google</p>
            </div>
          </div>

          <!-- 2 : Être crédible -->
          <div class="fade-in-up delay-300 flex lg:flex-col items-center gap-5 lg:gap-0 lg:text-center">
            <div class="relative z-10 w-16 h-16 rounded-full flex items-center justify-center flex-shrink-0" style="background:#E1EBF9; border:2px solid rgba(21,101,192,0.4);">
              <svg class="w-7 h-7" style="color:#1565C0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="lg:mt-4">
              <p class="font-bold text-sm text-gm-marine">Être crédible</p>
              <p class="text-xs mt-1 text-gray-400">Site web vitrine</p>
            </div>
          </div>

          <!-- 3 : Être mémorable -->
          <div class="fade-in-up delay-400 flex lg:flex-col items-center gap-5 lg:gap-0 lg:text-center">
            <div class="relative z-10 w-16 h-16 rounded-full flex items-center justify-center flex-shrink-0" style="background:#E1EBF9; border:2px solid rgba(21,101,192,0.4);">
              <svg class="w-7 h-7" style="color:#1565C0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
              </svg>
            </div>
            <div class="lg:mt-4">
              <p class="font-bold text-sm text-gm-marine">Être mémorable</p>
              <p class="text-xs mt-1 text-gray-400">Identité visuelle</p>
            </div>
          </div>

        </div>
      </div>

      <p class="text-center mt-12 text-sm text-gray-400 fade-in-up">
        Votre métier mérite d'être connu.
      </p>

    </div>
  </section>

  <!-- ============================
       NOS SERVICES — ce qu'on fait
       ============================ -->
  <section class="py-24" style="background:#080F2C;">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 fade-in-up">
        <span class="text-sm font-semibold uppercase tracking-widest" style="color:#42A5F5;">Ce qu'on fait</span>
        <h2 class="text-4xl font-extrabold text-white mt-2">Nos services</h2>
      </div>
      <div class="flex flex-col gap-16">

        <!-- B1 — Fiche Google -->
        <div class="relative fade-in-up">
          <span class="absolute -top-6 left-0 font-extrabold select-none pointer-events-none leading-none" style="font-size:clamp(80px,15vw,140px); color:rgba(255,255,255,0.04);">01</span>
          <div class="relative z-10 flex flex-col sm:flex-row gap-6 sm:gap-12 items-start pt-8">
            <div class="flex-shrink-0">
              <span class="text-5xl font-extrabold" style="color:#1565C0;">01</span>
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-extrabold text-white mb-3">Fiche Google Business</h3>
              <p class="leading-relaxed mb-5" style="color:rgba(255,255,255,0.55);">Quand quelqu'un cherche votre métier près de chez lui, il appelle celui qu'il trouve en premier. Soyez là avant vos concurrents.</p>
              <a href="/services" class="inline-flex items-center gap-2 font-semibold text-sm btn-transition" style="color:#42A5F5;">
                En savoir plus <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
          <div class="mt-8 rounded-2xl overflow-hidden" style="height:260px;">
            <img src="/service-google.jpg" alt="Fiche Google Business" class="w-full h-full object-cover" />
          </div>
        </div>

        <!-- Séparateur -->
        <div style="height:1px; background:rgba(255,255,255,0.07);"></div>

        <!-- B2 — Site web -->
        <div class="relative fade-in-up">
          <span class="absolute -top-6 left-0 font-extrabold select-none pointer-events-none leading-none" style="font-size:clamp(80px,15vw,140px); color:rgba(255,255,255,0.04);">02</span>
          <div class="relative z-10 flex flex-col sm:flex-row gap-6 sm:gap-12 items-start pt-8">
            <div class="flex-shrink-0">
              <span class="text-5xl font-extrabold" style="color:#1565C0;">02</span>
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-extrabold text-white mb-3">Site web vitrine</h3>
              <p class="leading-relaxed mb-5" style="color:rgba(255,255,255,0.55);">Un client qui entend parler de vous cherche votre site avant de vous appeler. Sans site, il doute. Votre vitrine travaille pour vous 24h/24.</p>
              <a href="/services" class="inline-flex items-center gap-2 font-semibold text-sm btn-transition" style="color:#42A5F5;">
                En savoir plus <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
          <div class="mt-8 rounded-2xl overflow-hidden" style="height:260px;">
            <img src="/service-vitrine.jpg" alt="Site web vitrine" class="w-full h-full object-cover" />
          </div>
        </div>

        <!-- Séparateur -->
        <div style="height:1px; background:rgba(255,255,255,0.07);"></div>

        <!-- B3 — Identité visuelle -->
        <div class="relative fade-in-up">
          <span class="absolute -top-6 left-0 font-extrabold select-none pointer-events-none leading-none" style="font-size:clamp(80px,15vw,140px); color:rgba(255,255,255,0.04);">03</span>
          <div class="relative z-10 flex flex-col sm:flex-row gap-6 sm:gap-12 items-start pt-8">
            <div class="flex-shrink-0">
              <span class="text-5xl font-extrabold" style="color:#1565C0;">03</span>
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-extrabold text-white mb-3">Identité visuelle</h3>
              <p class="leading-relaxed mb-5" style="color:rgba(255,255,255,0.55);">Logo, carte de visite, flyer — ce que votre client voit avant même de vous rencontrer. Une image soignée, c'est la différence entre quelqu'un qu'on appelle et quelqu'un qu'on oublie.</p>
              <a href="/services" class="inline-flex items-center gap-2 font-semibold text-sm btn-transition" style="color:#42A5F5;">
                En savoir plus <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
          <div class="mt-8 rounded-2xl overflow-hidden" style="height:260px;">
            <img src="/service-identite.jpg" alt="Identité visuelle" class="w-full h-full object-cover" />
          </div>
        </div>

      </div>
    </div>
  </section>


