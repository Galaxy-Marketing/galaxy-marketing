    draw4();
  }
</script>

<script>
  // Animation fiche Google — avis + étoiles
  const ratingEl = document.getElementById('gcard-rating');
  const reviewsEl = document.getElementById('gcard-reviews');
  const starFill = document.getElementById('gcard-star-fill');

  if (ratingEl && reviewsEl && starFill) {
    const duration = 2800;
    const startRating = 2.0, endRating = 5.0;
    const startReviews = 20, endReviews = 1000;
    setTimeout(() => {
      const t0 = performance.now();
      const tick = (now) => {
        const raw = Math.min((now - t0) / duration, 1);
        const eased = 1 - Math.pow(1 - raw, 3);
        const rating = startRating + (endRating - startRating) * eased;
        const reviews = Math.round(startReviews + (endReviews - startReviews) * eased);
        ratingEl.textContent = rating.toFixed(2);
        reviewsEl.textContent = '(' + reviews + ')';
        starFill.style.width = (rating / 5 * 100) + '%';
        if (raw < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }, 1200);
  }
</script>

<script>
  function makeStars(id: string, density: number) {
    const cvs = document.getElementById(id) as HTMLCanvasElement;
    if (!cvs) return;
    const ctx = cvs.getContext('2d')!;
    type S = { x:number; y:number; r:number; op:number; maxOp:number; minOp:number; tw:number; dir:number; };
    let stars: S[] = [];
    const resize = () => { cvs.width = cvs.offsetWidth; cvs.height = cvs.offsetHeight; };
    const init = () => {
      stars = [];
      const total = Math.max(20, Math.floor(cvs.width * cvs.height / density));
      for (let i = 0; i < total; i++) {
        const sz = Math.random();
        const r = sz < 0.65 ? Math.random() * 0.5 + 0.1 : sz < 0.9 ? Math.random() * 0.8 + 0.4 : Math.random() * 1.2 + 0.8;
        const minOp = Math.random() * 0.06 + 0.03;
        const maxOp = Math.random() * 0.40 + 0.20;
        stars.push({ x: Math.random() * cvs.width, y: Math.random() * cvs.height, r, op: Math.random() * (maxOp - minOp) + minOp, maxOp, minOp, tw: Math.random() * 0.002 + 0.0006, dir: Math.random() > 0.5 ? 1 : -1 });
      }
    };
    const draw = () => {
      ctx.clearRect(0, 0, cvs.width, cvs.height);
      stars.forEach(s => {
        s.op += s.tw * s.dir;
        if (s.op >= s.maxOp || s.op <= s.minOp) s.dir *= -1;
        s.op = Math.max(s.minOp, Math.min(s.maxOp, s.op));
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${s.op})`;
        ctx.fill();
      });
      requestAnimationFrame(draw);
    };
    window.addEventListener('resize', () => { resize(); init(); });
    resize(); init(); draw();
  }
  makeStars('engagements-stars-canvas', 5000);
  makeStars('cta-stars-canvas', 6000);
</script>
