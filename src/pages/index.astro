---
import Layout from '../layouts/Layout.astro';
import OffreCard from '../components/OffreCard.astro';
---

<Layout
  title="Galaxy Marketing — Votre présence digitale, pensée pour vous"
  description="Galaxy Marketing : agence spécialisée en site web vitrine, fiche Google Business et identité visuelle pour les entrepreneurs et entreprises locales."
>

  <!-- ============================
       HERO — fond nuit + particules étoiles
       ============================ -->
  <section class="relative min-h-screen flex items-center overflow-hidden" style="background:#0A0F2C;">

    <!-- Canvas particules étoiles -->
    <canvas id="stars-canvas" class="absolute inset-0 w-full h-full" aria-hidden="true"></canvas>

    <!-- Halo lumineux flou derrière le texte -->
    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full opacity-10 blur-3xl pointer-events-none" style="background:radial-gradient(circle, #42A5F5 0%, #1565C0 50%, transparent 100%);"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Texte gauche -->
        <div>
          <div class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 mb-8 border" style="background:rgba(66,165,245,0.1); border-color:rgba(66,165,245,0.3);">
            <span class="w-2 h-2 rounded-full animate-pulse" style="background:#42A5F5;"></span>
            <span class="text-sm font-medium" style="color:#42A5F5;">Agence marketing digitale</span>
          </div>

          <h1 class="text-5xl sm:text-6xl font-extrabold leading-tight mb-6 text-white">
            Votre présence digitale,<br />
            <span style="color:#42A5F5;">pensée pour vous.</span>
          </h1>

          <p class="text-xl mb-10 font-light" style="color:rgba(255,255,255,0.6);">
            Site web · Fiche Google · Identité visuelle
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#offres" class="text-white px-8 py-4 rounded-xl font-semibold text-lg btn-transition text-center" style="background:#1565C0;" onmouseover="this.style.background='#5C35B0'" onmouseout="this.style.background='#1565C0'">
              Voir nos offres
            </a>
            <a href="/contact" class="px-8 py-4 rounded-xl font-semibold text-lg btn-transition text-center border-2 text-white" style="border-color:rgba(255,255,255,0.3);" onmouseover="this.style.borderColor='#42A5F5';this.style.color='#42A5F5'" onmouseout="this.style.borderColor='rgba(255,255,255,0.3)';this.style.color='white'">
              Nous contacter
            </a>
          </div>
        </div>

        <!-- Visuel droite — mockup card -->
        <div class="relative hidden lg:block">
          <div class="rounded-2xl p-6 ml-8 border" style="background:rgba(255,255,255,0.05); border-color:rgba(255,255,255,0.1); backdrop-filter:blur(12px);">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
              <div class="flex-1 rounded-full h-4 ml-2" style="background:rgba(255,255,255,0.1);"></div>
            </div>
            <img
              src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=800&q=85"
              alt="Exemple site web professionnel"
              class="rounded-xl w-full h-48 object-cover mb-4 opacity-90"
            />
            <div class="grid grid-cols-3 gap-3">
              <div class="rounded-xl p-3 text-center" style="background:rgba(66,165,245,0.15);">
                <p class="font-bold text-lg" style="color:#42A5F5;">+85%</p>
                <p class="text-xs" style="color:rgba(255,255,255,0.5);">Visibilité</p>
              </div>
              <div class="rounded-xl p-3 text-center" style="background:rgba(92,53,176,0.2);">
                <p class="font-bold text-lg" style="color:#a78bfa;">3x</p>
                <p class="text-xs" style="color:rgba(255,255,255,0.5);">Plus de clients</p>
              </div>
              <div class="rounded-xl p-3 text-center" style="background:rgba(66,165,245,0.15);">
                <p class="font-bold text-lg" style="color:#42A5F5;">Pro</p>
                <p class="text-xs" style="color:rgba(255,255,255,0.5);">Qualité</p>
              </div>
            </div>
          </div>

          <!-- Badge flottant haut -->
          <div class="absolute -top-4 -right-4 rounded-2xl px-4 py-3 shadow-lg" style="background:#1565C0;">
            <p class="text-xs font-medium text-blue-200">Fiche Google</p>
            <p class="text-lg font-bold text-white">⭐ 5/5</p>
          </div>

          <!-- Badge flottant bas -->
          <div class="absolute -bottom-4 -left-4 rounded-2xl px-4 py-3 shadow-xl flex items-center gap-3" style="background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.12); backdrop-filter:blur(8px);">
            <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <p class="text-xs" style="color:rgba(255,255,255,0.5);">Site livré</p>
              <p class="text-sm font-bold text-white">En ligne ✓</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================
       PROMESSES — 4 valeurs clés
       ============================ -->
  <section class="py-14" style="background:#1A237E;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">

        <div class="fade-in-up flex flex-col items-center gap-3">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background:rgba(66,165,245,0.2);">
            <svg class="w-6 h-6" style="color:#42A5F5;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <p class="font-bold text-white">Devis gratuit</p>
          <p class="text-xs" style="color:rgba(255,255,255,0.5);">Sans engagement</p>
        </div>

        <div class="fade-in-up flex flex-col items-center gap-3">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background:rgba(66,165,245,0.2);">
            <svg class="w-6 h-6" style="color:#42A5F5;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <p class="font-bold text-white">Réponse sous 48h</p>
          <p class="text-xs" style="color:rgba(255,255,255,0.5);">Toujours disponible</p>
        </div>

        <div class="fade-in-up flex flex-col items-center gap-3">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background:rgba(66,165,245,0.2);">
            <svg class="w-6 h-6" style="color:#42A5F5;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
            </svg>
          </div>
          <p class="font-bold text-white">Résultat professionnel</p>
          <p class="text-xs" style="color:rgba(255,255,255,0.5);">Qualité à chaque livraison</p>
        </div>

        <div class="fade-in-up flex flex-col items-center gap-3">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background:rgba(66,165,245,0.2);">
            <svg class="w-6 h-6" style="color:#42A5F5;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <p class="font-bold text-white">Suivi de A à Z</p>
          <p class="text-xs" style="color:rgba(255,255,255,0.5);">Du brief à la livraison</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================
       NOS SERVICES — ce qu'on fait
       ============================ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-in-up">
        <span class="text-sm font-semibold uppercase tracking-widest" style="color:#1565C0;">Ce qu'on fait</span>
        <h2 class="text-4xl font-extrabold text-gm-marine mt-2 mb-4">Nos services</h2>
        <p class="text-gray-500 text-lg max-w-xl mx-auto">Trois expertises pour couvrir l'ensemble de votre présence digitale.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Service 1 -->
        <div class="group rounded-2xl p-8 border border-gray-100 card-hover fade-in-up transition-all duration-300 hover:border-blue-200" style="background:#F8FAFF;">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6" style="background:#1565C0;">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gm-marine mb-3">Site web vitrine</h3>
          <p class="text-gray-500 leading-relaxed mb-5">Un site moderne, responsive et optimisé pour convertir vos visiteurs en clients.</p>
          <a href="/services" class="text-sm font-semibold inline-flex items-center gap-1 btn-transition" style="color:#1565C0;">
            En savoir plus
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Service 2 -->
        <div class="group rounded-2xl p-8 border border-gray-100 card-hover fade-in-up transition-all duration-300 hover:border-blue-200" style="background:#F8FAFF;">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6" style="background:#1565C0;">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gm-marine mb-3">Fiche Google Business</h3>
          <p class="text-gray-500 leading-relaxed mb-5">Optimisation complète pour apparaître en tête des recherches locales et attirer plus de clients.</p>
          <a href="/services" class="text-sm font-semibold inline-flex items-center gap-1 btn-transition" style="color:#1565C0;">
            En savoir plus
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Service 3 -->
        <div class="group rounded-2xl p-8 border border-gray-100 card-hover fade-in-up transition-all duration-300 hover:border-blue-200" style="background:#F8FAFF;">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6" style="background:#1565C0;">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gm-marine mb-3">Identité visuelle</h3>
          <p class="text-gray-500 leading-relaxed mb-5">Logo, palette, typographies, carte de visite et flyer — une image de marque cohérente et professionnelle.</p>
          <a href="/services" class="text-sm font-semibold inline-flex items-center gap-1 btn-transition" style="color:#1565C0;">
            En savoir plus
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================
       COMMENT ÇA MARCHE — timeline humaine
       ============================ -->
  <section class="py-24" style="background:#F8FAFF;">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-in-up">
        <span class="text-sm font-semibold uppercase tracking-widest" style="color:#1565C0;">Le processus</span>
        <h2 class="text-4xl font-extrabold text-gm-marine mt-2 mb-4">Comment ça se passe ?</h2>
        <p class="text-gray-500 text-lg">Simple, clair, sans stress.</p>
      </div>

      <div class="flex flex-col gap-6">

        <!-- Étape 1 -->
        <div class="flex gap-6 items-start fade-in-up">
          <div class="flex flex-col items-center flex-shrink-0">
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center font-extrabold text-white text-lg shadow-lg" style="background:#1565C0;">1</div>
            <div class="w-0.5 h-full mt-2" style="background:#E0E7FF; min-height:40px;"></div>
          </div>
          <div class="pb-8">
            <h3 class="text-lg font-bold text-gm-marine mb-1">Tu nous contactes</h3>
            <p class="text-gray-500 leading-relaxed">Un message, un appel ou un formulaire — on échange sur ton projet en moins de 48h. C'est gratuit et sans engagement.</p>
          </div>
        </div>

        <!-- Étape 2 -->
        <div class="flex gap-6 items-start fade-in-up">
          <div class="flex flex-col items-center flex-shrink-0">
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center font-extrabold text-white text-lg shadow-lg" style="background:#5C35B0;">2</div>
            <div class="w-0.5 h-full mt-2" style="background:#E0E7FF; min-height:40px;"></div>
          </div>
          <div class="pb-8">
            <h3 class="text-lg font-bold text-gm-marine mb-1">On comprend ton besoin</h3>
            <p class="text-gray-500 leading-relaxed">On prend le temps de cerner ce qui te manque, ce qui marche déjà et ce qu'on peut faire ensemble. On te propose la solution la plus adaptée.</p>
          </div>
        </div>

        <!-- Étape 3 -->
        <div class="flex gap-6 items-start fade-in-up">
          <div class="flex flex-col items-center flex-shrink-0">
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center font-extrabold text-white text-lg shadow-lg" style="background:#1565C0;">3</div>
            <div class="w-0.5 h-full mt-2" style="background:#E0E7FF; min-height:40px;"></div>
          </div>
          <div class="pb-8">
            <h3 class="text-lg font-bold text-gm-marine mb-1">On crée, tu valides</h3>
            <p class="text-gray-500 leading-relaxed">On travaille sur ton projet et on te tient informé à chaque étape. Tu donnes ton avis, on ajuste jusqu'à ce que ce soit parfait.</p>
          </div>
        </div>

        <!-- Étape 4 -->
        <div class="flex gap-6 items-start fade-in-up">
          <div class="flex flex-col items-center flex-shrink-0">
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center font-extrabold text-white text-lg shadow-lg" style="background:#5C35B0;">4</div>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gm-marine mb-1">On livre, tout le monde est content</h3>
            <p class="text-gray-500 leading-relaxed">Ton projet est livré clé en main. Tu es en ligne, visible, professionnel. Et on reste disponible si tu as des questions.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================
       NOS OFFRES — les packs avec prix
       ============================ -->
  <section id="offres" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6 fade-in-up">
        <span class="text-sm font-semibold uppercase tracking-widest" style="color:#1565C0;">Les tarifs</span>
        <h2 class="text-4xl font-extrabold text-gm-marine mt-2 mb-4">Nos offres</h2>
        <p class="text-gray-500 text-lg max-w-xl mx-auto">Des formules claires avec tout ce qui est inclus, sans surprise.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center mb-16">
        <OffreCard
          name="Essentiel"
          price="À partir de 250€"
          features={['Fiche Google optimisée + visuels','3 posts Google planifiés','Carte NFC + QR code','Guide PDF offert']}
        />
        <OffreCard
          name="Pro"
          price="À partir de 900€"
          popular={true}
          features={["Tout l'Essentiel inclus",'Site web one-page professionnel','Design responsive mobile et desktop','Formulaire de contact intégré','Animations incluses']}
        />
        <OffreCard
          name="Galaxy"
          price="À partir de 1 200€"
          features={['Tout le Pro inclus','Logo + identité visuelle complète','Carte de visite et flyer','Livraison en haute résolution']}
        />
      </div>

      <!-- Options à la carte -->
      <div class="rounded-2xl p-8 border border-blue-100 fade-in-up" style="background:#F8FAFF;">
        <div class="text-center mb-8">
          <h3 class="text-2xl font-bold text-gm-marine mb-2">Options à la carte</h3>
          <p class="text-gray-500">À ajouter à n'importe quelle offre selon vos besoins.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="bg-white rounded-xl p-5 border border-gray-100 flex items-center justify-between gap-4">
            <div>
              <p class="font-semibold text-gm-marine text-sm">Pack 12 visuels réseaux sociaux</p>
              <p class="text-gray-400 text-xs mt-0.5">Posts personnalisés à vos couleurs</p>
            </div>
            <a href="/contact" class="text-xs font-bold px-3 py-2 rounded-lg text-white flex-shrink-0 btn-transition" style="background:#1565C0;">Devis</a>
          </div>
          <div class="bg-white rounded-xl p-5 border border-gray-100 flex items-center justify-between gap-4">
            <div>
              <p class="font-semibold text-gm-marine text-sm">Chatbot sur votre site</p>
              <p class="text-gray-400 text-xs mt-0.5">Assistant virtuel 24h/24</p>
            </div>
            <a href="/contact" class="text-xs font-bold px-3 py-2 rounded-lg text-white flex-shrink-0 btn-transition" style="background:#1565C0;">Devis</a>
          </div>
          <div class="bg-white rounded-xl p-5 border border-gray-100 flex items-center justify-between gap-4">
            <div>
              <p class="font-semibold text-gm-marine text-sm">Système de réservation en ligne</p>
              <p class="text-gray-400 text-xs mt-0.5">Réservations depuis votre site</p>
            </div>
            <a href="/contact" class="text-xs font-bold px-3 py-2 rounded-lg text-white flex-shrink-0 btn-transition" style="background:#1565C0;">Devis</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================
       TÉMOIGNAGES — 2 avis
       ============================ -->
  <section class="py-24" style="background:#F8FAFF;">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-in-up">
        <span class="text-sm font-semibold uppercase tracking-widest" style="color:#1565C0;">Avis clients</span>
        <h2 class="text-4xl font-extrabold text-gm-marine mt-2 mb-4">Ce qu'ils en pensent</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Avis 1 -->
        <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm card-hover fade-in-up">
          <div class="flex gap-1 mb-5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-gray-600 leading-relaxed mb-6 italic text-lg">
            "Je ne savais pas du tout par où commencer pour ma présence en ligne. Galaxy Marketing a tout géré, du site à la fiche Google. Le résultat est vraiment professionnel et j'ai déjà reçu de nouveaux clients grâce à ça."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full flex items-center justify-center font-bold text-white text-lg" style="background:#1565C0;">S</div>
            <div>
              <p class="font-semibold text-gm-marine">Sarah M.</p>
              <p class="text-gray-400 text-sm">Esthéticienne — Paris</p>
