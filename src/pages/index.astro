---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import OffreCard from '../components/OffreCard.astro';
---

<Layout
  title="Galaxy Marketing — Votre présence digitale, pensée pour vous"
  description="Galaxy Marketing : agence spécialisée en site web vitrine, fiche Google Business et identité visuelle pour les entrepreneurs et entreprises locales."
>

  <!-- ============================
       SECTION 1 — HERO (texte gauche + visuel droite)
       ============================ -->
  <section class="relative min-h-screen flex items-center bg-white overflow-hidden">
    <!-- Étoiles flottantes CSS -->
    <div class="stars-container" aria-hidden="true">
      <div class="star" style="top:10%; left:8%;  --duration:7s;  --delay:0s;"></div>
      <div class="star" style="top:20%; left:85%; --duration:9s;  --delay:1s;"></div>
      <div class="star" style="top:35%; left:15%; --duration:6s;  --delay:0.5s;"></div>
      <div class="star" style="top:55%; left:90%; --duration:8s;  --delay:2s;"></div>
      <div class="star" style="top:70%; left:5%;  --duration:10s; --delay:0.3s;"></div>
      <div class="star" style="top:80%; left:75%; --duration:7s;  --delay:1.5s;"></div>
      <div class="star" style="top:15%; left:50%; --duration:9s;  --delay:0.8s;"></div>
      <div class="star" style="top:65%; left:40%; --duration:6s;  --delay:2.5s;"></div>
      <div class="star" style="top:40%; left:70%; --duration:11s; --delay:0.2s;"></div>
      <div class="star" style="top:88%; left:30%; --duration:8s;  --delay:1.8s;"></div>
      <div class="star" style="top:5%;  left:35%; --duration:7s;  --delay:3s;"></div>
      <div class="star" style="top:50%; left:55%; --duration:9s;  --delay:0.7s;"></div>
      <div class="star" style="top:25%; left:28%; --duration:6s;  --delay:1.2s;"></div>
      <div class="star" style="top:75%; left:60%; --duration:10s; --delay:2.2s;"></div>
      <div class="star" style="top:92%; left:80%; --duration:8s;  --delay:0.4s;"></div>
      <div class="star" style="top:45%; left:22%; --duration:7s;  --delay:3.5s;"></div>
      <div class="star" style="top:30%; left:95%; --duration:9s;  --delay:1.6s;"></div>
      <div class="star" style="top:60%; left:12%; --duration:6s;  --delay:2.8s;"></div>
      <div class="star" style="top:82%; left:48%; --duration:11s; --delay:0.9s;"></div>
      <div class="star" style="top:18%; left:63%; --duration:8s;  --delay:1.4s;"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Texte gauche -->
        <div>
          <div class="inline-flex items-center gap-2 bg-blue-50 border border-blue-100 rounded-full px-4 py-1.5 mb-8">
            <span class="w-2 h-2 bg-gm-light rounded-full animate-pulse"></span>
            <span class="text-gm-blue text-sm font-medium">Agence marketing digitale</span>
          </div>

          <h1 class="text-5xl sm:text-6xl font-extrabold text-gm-marine leading-tight mb-6">
            Votre présence digitale,<br />
            <span class="text-gm-blue">pensée pour vous.</span>
          </h1>

          <p class="text-xl text-gray-500 mb-10 font-light">
            Site web · Fiche Google · Identité visuelle
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#offres" class="bg-gm-blue text-white px-8 py-4 rounded-xl font-semibold text-lg btn-transition hover:bg-gm-indigo shadow-lg shadow-blue-200 text-center">
              Voir nos offres
            </a>
            <a href="/contact" class="border-2 border-gm-marine text-gm-marine px-8 py-4 rounded-xl font-semibold text-lg btn-transition hover:bg-gm-marine hover:text-white text-center">
              Nous contacter
            </a>
          </div>
        </div>

        <!-- Visuel droite — mockup dashboard -->
        <div class="relative hidden lg:block">
          <div class="relative bg-white rounded-2xl shadow-2xl border border-gray-100 p-6 ml-8">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
              <div class="flex-1 bg-gray-100 rounded-full h-4 ml-2"></div>
            </div>
            <img
              src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=800&q=85"
              alt="Exemple site web professionnel"
              class="rounded-xl w-full h-48 object-cover mb-4"
            />
            <div class="grid grid-cols-3 gap-3">
              <div class="bg-blue-50 rounded-xl p-3 text-center">
                <p class="text-gm-blue font-bold text-lg">+85%</p>
                <p class="text-gray-500 text-xs">Visibilité</p>
              </div>
              <div class="bg-indigo-50 rounded-xl p-3 text-center">
                <p class="text-gm-indigo font-bold text-lg">3x</p>
                <p class="text-gray-500 text-xs">Plus de clients</p>
              </div>
              <div class="bg-blue-50 rounded-xl p-3 text-center">
                <p class="text-gm-blue font-bold text-lg">24h</p>
                <p class="text-gray-500 text-xs">Livraison</p>
              </div>
            </div>
          </div>
          <div class="absolute -top-4 -right-4 bg-gm-blue text-white rounded-2xl px-4 py-3 shadow-lg">
            <p class="text-xs font-medium">Fiche Google</p>
            <p class="text-lg font-bold">⭐ 4.9/5</p>
          </div>
          <div class="absolute -bottom-4 -left-4 bg-white border border-gray-100 rounded-2xl px-4 py-3 shadow-lg flex items-center gap-3">
            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
              <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-500">Site livré</p>
              <p class="text-sm font-bold text-gm-marine">En ligne ✓</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================
       SECTION 2 — STATS / CHIFFRES CLÉS
       ============================ -->
  <section class="py-16 bg-gm-marine">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="fade-in-up">
          <p class="text-4xl font-extrabold text-white mb-1">
            <span class="counter" data-target="50" data-suffix="+">50+</span>
          </p>
          <p class="text-blue-300 text-sm font-medium">Clients accompagnés</p>
        </div>
        <div class="fade-in-up">
          <p class="text-4xl font-extrabold text-white mb-1">
            <span class="counter" data-target="98" data-suffix="%">98%</span>
          </p>
          <p class="text-blue-300 text-sm font-medium">Clients satisfaits</p>
        </div>
        <div class="fade-in-up">
          <p class="text-4xl font-extrabold text-white mb-1">
            <span class="counter" data-target="3" data-suffix="j">3j</span>
          </p>
          <p class="text-blue-300 text-sm font-medium">Délai moyen livraison</p>
        </div>
        <div class="fade-in-up">
          <p class="text-4xl font-extrabold text-white mb-1">
            <span class="counter" data-target="5" data-suffix="★">5★</span>
          </p>
          <p class="text-blue-300 text-sm font-medium">Note moyenne Google</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================
       SECTION 3 — SERVICES
       ============================ -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-in-up">
        <h2 class="text-4xl font-extrabold text-gm-marine mb-4">Nos services</h2>
        <p class="text-gray-500 text-lg max-w-xl mx-auto">
          Tout ce qu'il faut pour une présence en ligne professionnelle et efficace.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <ServiceCard icon="computer" title="Site web vitrine" description="Sites vitrines modernes, responsives et optimisés pour attirer vos clients." />
        <ServiceCard icon="location" title="Fiche Google" description="Optimisation complète de votre fiche Google Business pour être trouvé localement." />
        <ServiceCard icon="star" title="Identité visuelle" description="Logo, carte de visite et flyer pour une image de marque professionnelle." />
      </div>
    </div>
  </section>

  <!-- ============================
       SECTION 4 — COMMENT ÇA MARCHE
       ============================ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-in-up">
        <h2 class="text-4xl font-extrabold text-gm-marine mb-4">Comment ça marche ?</h2>
        <p class="text-gray-500 text-lg">Un processus simple et transparent, de A à Z.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center fade-in-up">
          <div class="w-20 h-20 bg-gm-blue rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg shadow-blue-200">
            <span class="text-white text-3xl font-extrabold">1</span>
          </div>
          <h3 class="text-xl font-bold text-gm-marine mb-3">Brief & découverte</h3>
          <p class="text-gray-500 leading-relaxed text-sm">On échange sur votre projet, vos besoins et vos objectifs. Gratuit et sans engagement.</p>
        </div>
        <div class="text-center fade-in-up">
          <div class="w-20 h-20 bg-gm-indigo rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg shadow-indigo-200">
            <span class="text-white text-3xl font-extrabold">2</span>
          </div>
          <h3 class="text-xl font-bold text-gm-marine mb-3">Création & validation</h3>
          <p class="text-gray-500 leading-relaxed text-sm">On crée votre projet sur mesure. Vous validez chaque étape avec des retours illimités.</p>
        </div>
        <div class="text-center fade-in-up">
          <div class="w-20 h-20 bg-gm-light rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg shadow-blue-200">
            <span class="text-white text-3xl font-extrabold">3</span>
          </div>
          <h3 class="text-xl font-bold text-gm-marine mb-3">Livraison & mise en ligne</h3>
          <p class="text-gray-500 leading-relaxed text-sm">Votre projet est livré clé en main, mis en ligne et prêt à attirer vos clients.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================
       SECTION 5 — OFFRES
       ============================ -->
  <section id="offres" class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-20 fade-in-up">
        <h2 class="text-4xl font-extrabold text-gm-marine mb-4">Nos offres</h2>
        <p class="text-gray-500 text-lg max-w-xl mx-auto">Des formules claires et adaptées à chaque besoin et budget.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center">
        <OffreCard name="Essentiel" price="À partir de 250€" features={['Fiche Google optimisée + visuels','3 posts Google planifiés','Carte NFC + QR code','Guide PDF offert']} />
        <OffreCard name="Pro" price="À partir de 900€" popular={true} features={["Tout l'Essentiel inclus",'Site web one-page professionnel','Design responsive mobile et desktop','Formulaire de contact intégré','Animations incluses']} />
        <OffreCard name="Galaxy" price="À partir de 1 200€" features={['Tout le Pro inclus','Logo + identité visuelle complète','Carte de visite et flyer','Livraison en haute résolution']} />
      </div>
    </div>
  </section>

  <!-- ============================
       SECTION 6 — TÉMOIGNAGES
       ============================ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-in-up">
        <h2 class="text-4xl font-extrabold text-gm-marine mb-4">Ce que disent nos clients</h2>
        <p class="text-gray-500 text-lg">Ils nous ont fait confiance, voici leur retour.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Témoignage 1 -->
        <div class="bg-gray-50 rounded-2xl p-7 border border-gray-100 card-hover fade-in-up">
          <div class="flex gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-gray-600 leading-relaxed mb-6 italic">"Galaxy Marketing a transformé ma présence en ligne en quelques jours. Mon site est superbe et mes appels ont doublé depuis la mise en ligne !"</p>
          <div class="flex items-center gap-3">
            <div class="w-11 h-11 rounded-full bg-blue-100 flex items-center justify-center font-bold text-gm-blue text-lg">S</div>
            <div>
              <p class="font-semibold text-gm-marine text-sm">Sarah M.</p>
              <p class="text-gray-400 text-xs">Esthéticienne, Paris</p>
            </div>
          </div>
        </div>
        <!-- Témoignage 2 — carte bleue -->
        <div class="bg-gm-blue rounded-2xl p-7 card-hover fade-in-up">
          <div class="flex gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-yellow-300" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-blue-100 leading-relaxed mb-6 italic">"Résultat pro livré en 3 jours, exactement ce que je voulais. La fiche Google est au top et j'apparais maintenant dans les premiers résultats locaux."</p>
          <div class="flex items-center gap-3">
            <div class="w-11 h-11 rounded-full bg-white/20 flex items-center justify-center font-bold text-white text-lg">K</div>
            <div>
              <p class="font-semibold text-white text-sm">Karim B.</p>
              <p class="text-blue-200 text-xs">Plombier, Lyon</p>
            </div>
          </div>
        </div>
        <!-- Témoignage 3 -->
        <div class="bg-gray-50 rounded-2xl p-7 border border-gray-100 card-hover fade-in-up">
          <div class="flex gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-gray-600 leading-relaxed mb-6 italic">"Mon logo et mon identité visuelle sont exactement ce que j'imaginais. Très à l'écoute, réactif et le résultat est vraiment professionnel."</p>
          <div class="flex items-center gap-3">
            <div class="w-11 h-11 rounded-full bg-indigo-100 flex items-center justify-center font-bold text-gm-indigo text-lg">A</div>
            <div>
              <p class="font-semibold text-gm-marine text-sm">Amina T.</p>
              <p class="text-gray-400 text-xs">Créatrice de mode, Bordeaux</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================
       SECTION 7 — SERVICES À LA CARTE
       ============================ -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-in-up">
        <h2 class="text-4xl font-extrabold text-gm-marine mb-4">Besoin d'autre chose ?</h2>
        <p class="text-gray-500 text-lg">Des services supplémentaires selon vos besoins.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl p-7 border border-gray-100 shadow-sm card-hover fade-in-up flex flex-col gap-4">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-gm-marine">Pack 12 visuels réseaux sociaux</h3>
          <p class="text-gray-500 text-sm flex-1">12 visuels personnalisés aux couleurs de votre marque pour vos réseaux sociaux.</p>
          <a href="/contact" class="bg-gm-blue text-white text-center py-2.5 px-5 rounded-lg font-semibold text-sm btn-transition hover:bg-gm-indigo">Sur devis</a>
        </div>
        <div class="bg-white rounded-2xl p-7 border border-gray-100 shadow-sm card-hover fade-in-up flex flex-col gap-4">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-gm-marine">Chatbot sur site</h3>
          <p class="text-gray-500 text-sm flex-1">Assistant virtuel intégré à votre site pour répondre à vos visiteurs 24h/24.</p>
          <a href="/contact" class="bg-gm-blue text-white text-center py-2.5 px-5 rounded-lg font-semibold text-sm btn-transition hover:bg-gm-indigo">Sur devis</a>
        </div>
        <div class="bg-white rounded-2xl p-7 border border-gray-100 shadow-sm card-hover fade-in-up flex flex-col gap-4">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-gm-marine">Système de réservation en ligne</h3>
          <p class="text-gray-500 text-sm flex-1">Permettez à vos clients de réserver depuis votre site, à toute heure.</p>
          <a href="/contact" class="bg-gm-blue text-white text-center py-2.5 px-5 rounded-lg font-semibold text-sm btn-transition hover:bg-gm-indigo">Sur devis</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================
       SECTION 8 — POURQUOI GALAXY MARKETING
       ============================ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-in-up">
        <h2 class="text-4xl font-extrabold text-gm-marine mb-4">Pourquoi Galaxy Marketing ?</h2>
        <p class="text-gray-500 text-lg max-w-xl mx-auto">Ce qui nous différencie et fait la confiance de nos clients.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        <div class="flex gap-5 fade-in-up">
          <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gm-marine mb-2">Livraison rapide</h3>
            <p class="text-gray-500 leading-relaxed">Votre projet livré dans les meilleurs délais, sans compromettre la qualité.</p>
          </div>
        </div>
        <div class="flex gap-5 fade-in-up">
          <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
