---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact — Galaxy Marketing"
  description="Contactez Galaxy Marketing pour un devis gratuit. Site web, fiche Google, identité visuelle — nous répondons sous 24h."
>

  <!-- En-tête -->
  <section class="py-24 bg-gradient-to-br from-blue-50 to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-5xl font-extrabold text-gm-marine mb-5 fade-in-up">
        Parlons de votre projet
      </h1>
      <p class="text-xl text-gray-500 fade-in-up">
        Remplissez le formulaire, réponse sous 24h.
      </p>
    </div>
  </section>

  <!-- Formulaire + infos contact -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">

        <!-- Formulaire — 3/5 -->
        <div class="lg:col-span-3 bg-white rounded-2xl shadow-sm border border-gray-100 p-8 fade-in-up">
          <form
            action="mailto:contact@galaxy-marketing.fr"
            method="POST"
            enctype="text/plain"
            class="flex flex-col gap-6"
          >
            <!-- Nom complet -->
            <div>
              <label for="nom" class="block text-sm font-semibold text-gray-700 mb-1.5">
                Nom complet <span class="text-gm-blue">*</span>
              </label>
              <input
                type="text"
                id="nom"
                name="nom"
                required
                placeholder="Ex : Jean Dupont"
                class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-gm-light focus:border-transparent transition"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">
                Email <span class="text-gm-blue">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="votre@email.com"
                class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-gm-light focus:border-transparent transition"
              />
            </div>

            <!-- Téléphone -->
            <div>
              <label for="telephone" class="block text-sm font-semibold text-gray-700 mb-1.5">
                Téléphone
              </label>
              <input
                type="tel"
                id="telephone"
                name="telephone"
                placeholder="06 12 34 56 78"
                class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-gm-light focus:border-transparent transition"
              />
            </div>

            <!-- Type de service -->
            <div>
              <label for="service" class="block text-sm font-semibold text-gray-700 mb-1.5">
                Type de service <span class="text-gm-blue">*</span>
              </label>
              <select
                id="service"
                name="service"
                required
                class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-800 focus:outline-none focus:ring-2 focus:ring-gm-light focus:border-transparent transition bg-white"
              >
                <option value="" disabled selected>Choisir une option...</option>
                <option value="Essentiel">Offre Essentiel (à partir de 250€)</option>
                <option value="Pro">Offre Pro (à partir de 900€)</option>
                <option value="Galaxy">Offre Galaxy (à partir de 1 200€)</option>
                <option value="Service à la carte">Service à la carte</option>
                <option value="Autre">Autre / Question</option>
              </select>
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-semibold text-gray-700 mb-1.5">
                Message <span class="text-gm-blue">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Décrivez votre projet, vos besoins, vos questions..."
                class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-gm-light focus:border-transparent transition resize-none"
              ></textarea>
            </div>

            <!-- Bouton envoi -->
            <button
              type="submit"
              class="w-full bg-gm-blue text-white py-4 px-6 rounded-xl font-bold text-lg btn-transition hover:bg-gm-indigo shadow-lg shadow-blue-200"
            >
              Envoyer ma demande
            </button>
          </form>
        </div>

        <!-- Bloc infos contact — 2/5 -->
        <div class="lg:col-span-2 flex flex-col gap-8 fade-in-up">
          <div>
            <h2 class="text-2xl font-extrabold text-gm-marine mb-2">Nos coordonnées</h2>
            <p class="text-gray-500">Disponibles pour répondre à toutes vos questions.</p>
          </div>

          <!-- Email -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-700 mb-0.5">Email</p>
              <a
                href="mailto:contact@galaxy-marketing.fr"
                class="text-gm-blue hover:text-gm-indigo btn-transition font-medium"
              >
                contact@galaxy-marketing.fr
              </a>
            </div>
          </div>

          <!-- Téléphone -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-700 mb-0.5">Téléphone</p>
              <a
                href="tel:0759701730"
                class="text-gm-blue hover:text-gm-indigo btn-transition font-medium"
              >
                07 59 70 17 30
              </a>
            </div>
          </div>

          <!-- Délai de réponse -->
          <div class="bg-blue-50 rounded-2xl p-6 border border-blue-100">
            <div class="flex items-center gap-3 mb-2">
              <svg class="w-5 h-5 text-gm-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p class="font-semibold text-gm-marine">Réponse rapide</p>
            </div>
            <p class="text-gray-500 text-sm">
              Nous répondons à toutes les demandes sous <strong>24 heures ouvrées</strong>. Devis entièrement gratuit et sans engagement.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
