---
// Layout principal — Navbar + Footer sur toutes les pages
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white text-gray-800 antialiased">
    <Navbar />
    <main class="pt-16">
      <slot />
    </main>
    <Footer />
    <!-- Script animations globales -->
    <script src="/animations.js" defer></script>
    <!-- Curseur étoile filante -->
    <script>
      if (window.matchMedia('(pointer: fine)').matches) {
        const dot = document.createElement('div');
        dot.className = 'gm-cursor';
        document.body.appendChild(dot);

        const TRAIL = 18;
        const trails: HTMLDivElement[] = [];
        const hist: {x:number; y:number}[] = Array.from({ length: TRAIL }, () => ({ x: -300, y: -300 }));

        for (let i = 0; i < TRAIL; i++) {
          const t = document.createElement('div') as HTMLDivElement;
          t.className = 'gm-cursor-trail';
          const size = Math.max(1.4, 5.5 - i * 0.23);
          t.style.cssText = `width:${size}px;height:${size}px;opacity:${((1 - i / TRAIL) * 0.78).toFixed(2)};`;
          document.body.appendChild(t);
          trails.push(t);
        }

        let mx = -300, my = -300;

        document.addEventListener('mousemove', e => {
          mx = e.clientX; my = e.clientY;
          dot.style.left = mx + 'px';
          dot.style.top = my + 'px';
        });

        (function loop() {
          hist.unshift({ x: mx, y: my });
          hist.length = TRAIL;
          trails.forEach((t, i) => {
            t.style.left = hist[i].x + 'px';
            t.style.top = hist[i].y + 'px';
          });
          requestAnimationFrame(loop);
        })();
      }
    </script>
  </body>
</html>
